# Where the dashboard Vite dev server should proxy /api and /ws to.
# Default (when unset): 127.0.0.1:8000 — local uvicorn.
#
# Split-machine setup: dashboard on your workstation, backend + stream on
# a broadcast VM. Copy this file to web/.env.local and set the VM's
# LAN IP and port here. .env.local is git-ignored by Vite convention.
#
# Example:
#   TRADEFARM_BACKEND=192.168.1.50:8000
TRADEFARM_BACKEND=127.0.0.1:8000
