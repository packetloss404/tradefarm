{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions for the broadcast window: read/write the stream-settings.json file under AppData and toggle the window fullscreen.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-fullscreen",
    "core:window:allow-is-fullscreen",
    "core:window:allow-close",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{ "path": "$APPDATA/stream-settings.json" }]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "$APPDATA/stream-settings.json" }]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [{ "path": "$APPDATA/stream-settings.json" }]
    }
  ]
}
