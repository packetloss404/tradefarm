# EODHD market data — https://eodhd.com
EODHD_API_KEY=

# Alpaca paper trading — https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Anthropic (for LLM decision layer — optional until that module lands)
ANTHROPIC_API_KEY=

# App
DATABASE_URL=sqlite+aiosqlite:///./tradefarm.db
LOG_LEVEL=INFO
AGENT_COUNT=100
AGENT_STARTING_CAPITAL=1000

# YouTube Live Chat — replaces the simulated audience strip with real messages
# from the active YouTube broadcast. Create a Desktop OAuth client in Google
# Cloud Console (APIs & Services -> Credentials), enable YouTube Data API v3,
# then run: `uv run python -m tradefarm.tools.youtube_auth` to capture the
# refresh token. Leave YOUTUBE_CHAT_ENABLED=false to keep the poller dormant.
YOUTUBE_CHAT_ENABLED=false
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=
